<Window x:Class="ImageFilterApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Медианная фильтрация" 
        Width="1300" Height="800" 
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1A1A2E"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Двуцветная палитра -->
        <Color x:Key="PrimaryColor">#0F3460</Color>
        <Color x:Key="AccentColor">#E94560</Color>
        <Color x:Key="BackgroundDark">#1A1A2E</Color>
        <Color x:Key="SurfaceColor">#16213E</Color>
        <Color x:Key="TextPrimary">#FFFFFF</Color>
        <Color x:Key="TextSecondary">#B0B0B0</Color>

        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundDark}"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>

        <!-- Стили для современного интерфейса -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="15,0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ModernCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" Opacity="0.3" ShadowDepth="2" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusBarStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель с заголовком -->
        <Border Grid.Row="0" 
                Style="{StaticResource ModernCard}"
                Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🎨" FontSize="24" Margin="0,-5,10,0" Foreground="{StaticResource AccentBrush}"/>
                    <StackPanel>
                        <TextBlock Text="Медианная фильтрация изображений" 
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Статистика -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#2A2A4A" CornerRadius="4" Padding="10,5" Margin="0,0,10,0">
                        <TextBlock x:Name="txtImageInfo" Text="Изображение не загружено" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - Управление -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,15,0">
                <StackPanel>
                    <!-- Карточка загрузки -->
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="📁 Загрузка" 
                   FontSize="14" 
                   FontWeight="SemiBold" 
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,10"/>
                            <Button x:Name="btnLoad" 
                Content="📂 Выбрать изображение" 
                Style="{StaticResource ModernButton}"
                Background="{StaticResource PrimaryBrush}"
                Click="btnLoad_Click"
                Margin="0,0,0,10"/>
                            <Button x:Name="btnSave" 
                Content="💾 Сохранить изображение" 
                Style="{StaticResource ModernButton}"
                Background="{StaticResource PrimaryBrush}"
                Click="btnSave_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка шума -->
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🌪️ Импульсный шум (Соль/Перец)" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"/>

                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Интенсивность:" 
                                           VerticalAlignment="Center" 
                                           Margin="0,0,10,0"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>

                                <Slider x:Name="sliderNoise" 
                                        Grid.Column="1" 
                                        Minimum="0" Maximum="100" 
                                        Value="10" 
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        VerticalAlignment="Center"
                                        Foreground="{StaticResource AccentBrush}"/>
                                <TextBlock Grid.Column="2" 
                                           Text="{Binding ElementName=sliderNoise, Path=Value, StringFormat={}{0:0}%}" 
                                           Margin="10,0,0,0"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource AccentBrush}"/>
                            </Grid>

                            <Button x:Name="btnAddNoise" 
                                    Content="➕ Добавить шум" 
                                    Style="{StaticResource ModernButton}"
                                    Background="#C73E5A"
                                    Click="btnAddNoise_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Карточка фильтрации -->
                    <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="🔧 Фильтрация" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"/>

                            <!-- Выбор размера маски -->
                            <TextBlock Text="Размер маски:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="0,0,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <RadioButton x:Name="rbMask3x3" 
                                             Content="3x3" 
                                             GroupName="MaskSize"
                                             IsChecked="True"
                                             Margin="0,0,15,0"
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                                <RadioButton x:Name="rbMask5x5" 
                                             Content="5x5" 
                                             GroupName="MaskSize"
                                             Margin="0,0,15,0"
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                                <RadioButton x:Name="rbMask7x7" 
                                             Content="7x7" 
                                             GroupName="MaskSize"
                                             Margin="0,0,15,0"
                                             Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>

                            <TextBlock Text="Классический метод:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="0,0,0,5"/>
                            <Button x:Name="btnMedianFilter" 
                                    Content="🔧 Медианный фильтр" 
                                    Style="{StaticResource ModernButton}"
                                    Background="{StaticResource PrimaryBrush}"
                                    Click="btnMedianFilter_Click"
                                    Margin="0,0,0,10"/>

                            <TextBlock Text="Взвешенный метод:" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       Margin="0,0,0,5"/>
                            <Button x:Name="btnWeightedMedianFilter" 
                                    Content="🔧 Взвешенный медианный" 
                                    Style="{StaticResource ModernButton}"
                                    Background="{StaticResource PrimaryBrush}"
                                    Click="btnWeightedMedianFilter_Click"/>

                            <Border Background="#1A2A4A" 
                                    CornerRadius="4" 
                                    Padding="8"
                                    Margin="0,10,0,0">
                                <TextBlock Text="ℹ️ Крестообразная маска для взвешенного метода" 
                                           FontSize="11"
                                           Foreground="#8A9BB0"
                                           TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Карточка просмотра -->
                    <Border Style="{StaticResource ModernCard}">
                        <StackPanel>
                            <TextBlock Text="👁️ Режим просмотра" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,10"/>

                            <RadioButton x:Name="rbOriginal" 
                                         Content="🖼️ Оригинал (клавиша O)" 
                                         GroupName="ViewMode"
                                         Checked="ViewMode_Checked"
                                         Margin="0,5"
                                         FontSize="13"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton x:Name="rbNoisy" 
                                         Content="🌪️ С шумом (клавиша N)" 
                                         GroupName="ViewMode"
                                         Checked="ViewMode_Checked"
                                         Margin="0,5"
                                         FontSize="13"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>
                            <RadioButton x:Name="rbRestored" 
                                         Content="✅ Восстановленное (клавиша R)" 
                                         GroupName="ViewMode"
                                         IsChecked="True"
                                         Checked="ViewMode_Checked"
                                         Margin="0,5"
                                         FontSize="13"
                                         Foreground="{StaticResource TextSecondaryBrush}"/>

                            <Border Background="#1A2A4A" 
                                    CornerRadius="4" 
                                    Padding="10"
                                    Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="🖱️ Колесико мыши - масштаб" 
                                               FontSize="11"
                                               Foreground="#8A9BB0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Правая панель - Изображение -->
            <Border Grid.Column="1" 
                    Style="{StaticResource ModernCard}"
                    Padding="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель инструментов изображения -->
                    <Border Grid.Row="0" 
        Background="#1A2A4A" 
        CornerRadius="6" 
        Padding="10"
        Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">

                                <Button x:Name="btnZoomIn" 
                    Content="➕" 
                    Style="{StaticResource IconButton}"
                    Margin="0,0,5,0"
                    Click="btnZoomIn_Click"
                    ToolTip="Увеличить (колесико мыши вверх)"/>
                                <Button x:Name="btnZoomOut" 
                    Content="➖" 
                    Style="{StaticResource IconButton}"
                    Margin="0,0,5,0"
                    Click="btnZoomOut_Click"
                    ToolTip="Уменьшить (колесико мыши вниз)"/>
                                <Button x:Name="btnZoomReset" 
                    Content="🔄" 
                    Style="{StaticResource IconButton}"
                    Margin="0,0,5,0"
                    Click="btnZoomReset_Click"
                    ToolTip="Сбросить масштаб (100%)"/>

                                
                                <Button x:Name="btnFitToView" 
                    Content="FIT" 
                    Style="{StaticResource IconButton}"
                    Margin="0,0,10,0"
                    Click="btnFitToView_Click"
                    ToolTip="Подогнать под размер окна (Ctrl+F)"/>

                            </StackPanel>

                            <!-- Индикатор масштаба -->
                            <Border Background="{StaticResource AccentBrush}" 
                CornerRadius="4" 
                Padding="10,5">
                                <TextBlock x:Name="txtZoom" 
                       Text="100%" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontWeight="Bold"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Область изображения -->
                    <Border Grid.Row="1" 
                            Background="#0A0A1A" 
                            CornerRadius="6">
                        <ScrollViewer x:Name="scrollViewer" 
                                      HorizontalScrollBarVisibility="Auto" 
                                      VerticalScrollBarVisibility="Auto"
                                      Background="#0A0A1A">
                            <Grid>
                                <Grid.RenderTransform>
                                    <ScaleTransform x:Name="imageScale" ScaleX="1" ScaleY="1"/>
                                </Grid.RenderTransform>
                                <Image x:Name="displayImage" 
                                       Stretch="None"
                                       HorizontalAlignment="Left" 
                                       VerticalAlignment="Top"
                                       MouseWheel="displayImage_MouseWheel"/>
                            </Grid>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя панель - Статус и прогресс -->
        <Border Grid.Row="2" 
                Style="{StaticResource StatusBarStyle}"
                Margin="0,15,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="300"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="txtStatus" 
                               Text="✅ Готов к работе" 
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" 
                               Text="Прогресс:" 
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                    <ProgressBar x:Name="progressBar" 
                                 Grid.Column="1"
                                 Height="8" 
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="#2A2A4A"
                                 BorderThickness="0"
                                 Value="0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>